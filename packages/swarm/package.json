{
  "name": "zouroboros-swarm",
  "version": "5.0.0",
  "description": "Production multi-agent orchestration with circuit breakers, 6-signal routing, DAG execution, tier-resolve, and MCP transport",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/marlandoj/zouroboros.git",
    "directory": "packages/swarm"
  },
  "bin": {
    "zouroboros-swarm": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "bun test src/__tests__/",
    "orchestrate": "bun scripts/orchestrate-v5.ts",
    "doctor": "bun scripts/orchestrate-v5.ts doctor",
    "status": "bun scripts/orchestrate-v5.ts status",
    "bench": "bun scripts/swarm-bench.ts",
    "tier-resolve": "bun scripts/tier-resolve.ts",
    "dep-graph": "bun scripts/dep-graph.ts",
    "mcp": "bun scripts/mcp-server.ts",
    "mcp-http": "bun scripts/mcp-server-http.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.18.0",
    "hono": "^4.12.12",
    "zouroboros-core": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "swarm",
    "orchestration",
    "multi-agent",
    "circuit-breaker",
    "routing",
    "dag",
    "tier-resolve",
    "mcp",
    "zouroboros"
  ],
  "license": "MIT",
  "author": "marlandoj.zo.computer"
}
