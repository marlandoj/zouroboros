{
  "name": "zouroboros-memory",
  "version": "2.0.0",
  "description": "Hybrid SQLite + Vector memory system for Zouroboros",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "zouroboros-memory": "./dist/cli.js",
    "zouroboros-memory-mcp": "./dist/mcp-server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "bun test src/",
    "test:coverage": "bun test --coverage src/",
    "cli": "bun ./src/cli.ts",
    "mcp": "bun ./src/mcp-server.ts"
  },
  "dependencies": {
    "zouroboros-core": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "zouroboros",
    "memory",
    "sqlite",
    "vector-search",
    "embeddings",
    "episodic-memory"
  ],
  "license": "MIT"
}
