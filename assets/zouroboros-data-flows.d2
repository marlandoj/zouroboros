direction: right

title: "Zouroboros Data Flows"

memory: |md
  ## Memory Capture & Briefing
  1. Conversation / workspace artifacts
  2. `conversation-capture`  
     default: last 24h  
     full replay requires `--all`
  3. `model-client` for extraction + embeddings
  4. SQLite facts / episodes / procedures
  5. Knowledge graph + contradiction handling
  6. `memory-gate` → session briefing / Mimir synthesis
|
memory.style.fill: "#E0F2FE"
memory.style.stroke: "#CBD5E1"
memory.style.stroke-width: 2
memory.style.border-radius: 12

swarm: |md
  ## Swarm Execution
  1. Seed spec / YAML
  2. Seed validation gate
  3. Parse DAG + stream ready tasks
  4. Executor selector  
     6-signal core + budget/role-aware 8-signal path
  5. RAG prefetch  
     Ollama embeddings + Qdrant
  6. Transport factory → Claude / Gemini / Codex / Hermes / Mimir
  7. Streaming task results
|
swarm.style.fill: "#F3E8FF"
swarm.style.stroke: "#CBD5E1"
swarm.style.stroke-width: 2
swarm.style.border-radius: 12

evaluation: |md
  ## Evaluation & Feedback
  1. Post-flight eval
  2. Gap audit loop
  3. Fallbacks, reroutes, budget accounting, telemetry
  4. Reusable episodes / facts fed back into memory
|
evaluation.style.fill: "#FEF3C7"
evaluation.style.stroke: "#CBD5E1"
evaluation.style.stroke-width: 2
evaluation.style.border-radius: 12

operations: |md
  ## Health & Scheduled Maintenance
  - Health Council diagnostics
  - Memory embedding backfill
  - Daily memory capture
  - Unified decay
  - Self-enhancement summary
  - Vault indexer
|
operations.style.fill: "#DCFCE7"
operations.style.stroke: "#CBD5E1"
operations.style.stroke-width: 2
operations.style.border-radius: 12

memory -> swarm: "context injection"
swarm -> evaluation: "execution results"
evaluation -> memory: "store reusable knowledge"
operations -> memory: "maintenance + capture"
operations -> evaluation: "drift diagnosis"
